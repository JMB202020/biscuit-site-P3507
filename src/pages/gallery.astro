---
import '../styles/site.css';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gallery | Hound And About</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/P3507/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/P3507/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2 px-4 text-center text-sm">
      <div class="max-w-4xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span>Preview for <strong>Hound And About</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=P3507&name=Hound%20And%20About" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-border sticky top-0 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/P3507" class="font-display font-extrabold text-xl text-ink">🐾 Hound And About</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav-P3507').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/P3507" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Home</a>
          <a href="/P3507/services" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Services</a>
          <a href="/P3507/gallery" class="text-sm text-brand-accent font-semibold transition-colors">Gallery</a>
          <a href="/P3507/contact" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Contact</a>
          <a href="/P3507/contact" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">Get in touch</a>
        </nav>
      </div>
      <nav id="mobile-nav-P3507" class="hidden md:hidden px-6 pb-4 space-y-3">
        <a href="/P3507" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Home</a>
        <a href="/P3507/services" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Services</a>
        <a href="/P3507/gallery" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Gallery</a>
        <a href="/P3507/contact" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Contact</a>
        <a href="/P3507/contact" class="block px-5 py-2.5 bg-brand-accent text-white font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">Get in touch</a>
      </nav>
    </header>


    <section class="relative py-20 sm:py-28 overflow-hidden">
      <img src="/P3507/images/480631570-1644264533032992-1587684549759-3.jpg" alt="" class="absolute inset-0 w-full h-full object-cover z-[1]" loading="lazy" />
      <div class="absolute inset-0 z-[2] bg-black/60"></div>
      <div class="relative z-[3] mx-auto max-w-4xl px-6">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white">Gallery</h1>
        <p class="mt-4 text-white/70 text-lg">Hound And About in action.</p>
      </div>
    </section>

    <section class="bg-cream-dark py-20">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-ink mb-10 text-center">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-2 gap-3">
          
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/490272323-1688847241908054-7306327748465-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480631570-1644264533032992-1587684549759-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/301485470-1030158657776919-1878944658972-4.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480401725-1644264669699645-5054761687556-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480259390-1644264466366332-7535348821275-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480577326-1644264653032980-6114231236042-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/476869854-1639079783551467-7036839918195-5.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480331721-1644264439699668-9096579258108-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/480461778-1644264679699644-1331592479470-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3507/images/logo-fblogo-blueprint.png" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>


    <footer class="bg-cream-dark border-t border-border py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col md:flex-row justify-between gap-8">
          <div>
            <p class="font-display font-extrabold text-lg text-ink">Hound And About</p>
            <p class="mt-2 text-ink-soft text-sm">6 Ryde's Hill Rd  Guildford GU2 9ST</p>
            <p class="mt-2"><a href="tel:07999883276" class="text-brand-accent hover:underline text-sm">07999 883276</a></p>
            <p class="mt-1"><a href="mailto:houndandabout123@gmail.com" class="text-brand-accent hover:underline text-sm">houndandabout123@gmail.com</a></p>
          </div>
          
          <nav class="flex flex-wrap gap-6">
            <a href="/P3507" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Home</a>
            <a href="/P3507/services" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Services</a>
            <a href="/P3507/gallery" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Gallery</a>
            <a href="/P3507/contact" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-border">
          <p class="text-ink-whisper text-xs">&copy; 2026 Hound And About. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
